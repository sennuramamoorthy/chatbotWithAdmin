{
  "name": "takshashila-admin-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Self-contained admin web UI for the Takshashila University chatbot admin API",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/main.ts --bundle --minify --format=iife --outfile=dist/admin.js"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "esbuild": "^0.24.2",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
